{
  "extends": ["stylelint-config-standard", "stylelint-config-recommended-scss"],
  "rules": {
    "at-rule-no-unknown": [true, {
      "ignoreAtRules": ["tailwind", "apply", "layer", "config"]
    }]
  },
  "overrides": [
    {
      "files": ["**/*.css"],
      "customSyntax": "postcss-html"
    }
  ]
}
